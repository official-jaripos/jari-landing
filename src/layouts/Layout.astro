---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
	type?: string;
	image?: string;
	canonicalURL?: string | URL;
	keywords?: string;
	gtmId?: string;
}

const { 
	title, 
	description = "Jaripos adalah platform Point of Sales (POS) yang memudahkan pengelolaan transaksi dan operasional bisnis Anda secara efisien dan terintegrasi.",
	type = "website",
	image = "/assets/images/og-image.png",
	canonicalURL = new URL(Astro.url.pathname, Astro.url.origin),
	keywords = "aplikasi kasir, POS umkm, point of sales, kasir online, manajemen stok, jaripos, jari pos",
	gtmId = "GTM-TZGSJ83F"
} = Astro.props;
---

<!doctype html>
<html lang="id" class="scroll-smooth overflow-x-hidden" style="scroll-padding-top: 80px;">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="keywords" content={keywords} />
		<meta name="robots" content="index, follow" />
		<meta name="author" content="Jaripos" />
		<meta http-equiv="content-language" content="id" />
		<link rel="canonical" href={canonicalURL} />

		<!-- Open Graph / Facebook / WhatsApp -->
		<meta property="og:type" content={type} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:site_name" content="Jaripos" />
		<meta property="og:image" content={new URL(image, canonicalURL).href} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:type" content="image/png" />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:url" content={canonicalURL} />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={new URL(image, canonicalURL).href} />

		<!-- Google Tag Manager -->
		{gtmId && (
			<script is:inline set:html={`
				(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
				new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
				j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
				'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
				})(window,document,'script','dataLayer','${gtmId}');
			`} />
		)}
		<!-- End Google Tag Manager -->

		<!-- Schema.org Structured Data (JSON-LD) -->
		<script type="application/ld+json" is:inline>
		{
			"@context": "https://schema.org",
			"@graph": [
				{
					"@type": "WebSite",
					"@id": "https://jaripos.com/#website",
					"url": "https://jaripos.com/",
					"name": "Jaripos",
					"alternateName": ["Jari POS", "JariPos", "Jaripos.com", "JARIPOS"],
					"publisher": {
						"@id": "https://jaripos.com/#organization"
					}
				},
				{
					"@type": "Organization",
					"@id": "https://jaripos.com/#organization",
					"name": "Jaripos",
					"url": "https://jaripos.com",
					"logo": "https://jaripos.com/LOGO-JARI-WHITE.png",
					"email": "official.jaripos@gmail.com",
					"description": "JariPOS adalah aplikasi kasir (POS) berbasis AI untuk UMKM di Indonesia.",
					"address": {
						"@type": "PostalAddress",
						"addressLocality": "Semarang",
						"addressRegion": "Jawa Tengah",
						"addressCountry": "ID"
					},
					"sameAs": [
						"https://www.instagram.com/official.jaripos",
						"https://www.tiktok.com/@official.jaripos"
					]
				},
				{
					"@type": "SoftwareApplication",
					"@id": "https://jaripos.com/#software",
					"name": "JARIPOS",
					"applicationCategory": "BusinessApplication",
					"applicationSubCategory": "AI-powered Point of Sale (POS)",
					"operatingSystem": "Web, Android, iOS",
					"description": "JariPOS adalah aplikasi kasir (POS) berbasis AI untuk UMKM di Indonesia yang membantu mengelola penjualan, stok, pelanggan, dan memberikan insight bisnis secara cerdas.",
					"url": "https://jaripos.com",
					"image": "https://jaripos.com/logo.png",
					"featureList": [
						"AI Business Assistant",
						"AI Inventory Management",
						"AI Sales Analytics",
						"Point of Sale (POS)",
						"Inventory Management",
						"Customer Management",
						"Multi Outlet",
						"Digital Payment",
						"Sales Reporting"
					],
					"author": {
						"@id": "https://jaripos.com/#organization"
					}
				},
				{
					"@type": "ItemList",
					"@id": "https://jaripos.com/#navigation",
					"name": "Menu Navigasi Utama",
					"itemListElement": [
						{
							"@type": "SiteNavigationElement",
							"position": 1,
							"name": "Kenapa JARIPOS?",
							"url": "https://jaripos.com/#comparison"
						},
						{
							"@type": "SiteNavigationElement",
							"position": 2,
							"name": "Cocok untuk Siapa?",
							"url": "https://jaripos.com/#target-market"
						},
						{
							"@type": "SiteNavigationElement",
							"position": 3,
							"name": "Fitur",
							"url": "https://jaripos.com/#features"
						},
						{
							"@type": "SiteNavigationElement",
							"position": 4,
							"name": "Harga",
							"url": "https://jaripos.com/#pricing"
						},
						{
							"@type": "SiteNavigationElement",
							"position": 5,
							"name": "Kemitraan Afiliasi",
							"url": "https://jaripos.com/affiliate"
						},
						{
							"@type": "SiteNavigationElement",
							"position": 6,
							"name": "Masuk Aplikasi",
							"url": "https://app.jaripos.com"
						}
					]
				}
			]
		}
		</script>
		<!-- End Schema.org Structured Data -->
		
		<!-- PWA Meta Tags -->
		<meta name="theme-color" content="#0ea5e9">
		<meta name="apple-mobile-web-app-capable" content="yes">
		<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
		<meta name="apple-mobile-web-app-title" content="Jaripos">
		<meta name="mobile-web-app-capable" content="yes">
		<meta name="application-name" content="Jaripos">
		<meta name="msapplication-TileColor" content="#0ea5e9">
		
		<!-- PWA Manifest & Icons -->
		<link rel="manifest" href="/manifest.json">
		<link rel="shortcut icon" href="/FAV-JARI-BLACK.png">
		<link rel="apple-touch-icon" href="/FAV-JARI-BLACK.png">
		
		<!-- Fonts & Icons -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Outfit:wght@700;900&display=swap" onload="this.onload=null;this.rel='stylesheet'">
		<noscript><link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Outfit:wght@700;900&display=swap" rel="stylesheet"></noscript>
		
		<!-- Fix missing local webfonts by using CDN -->
		<link rel="preload" as="style" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" onload="this.onload=null;this.rel='stylesheet'">
		<noscript><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"></noscript>
		
		<!-- Animation CSS -->
		<link rel="preload" as="style" href="/assets/css/aos.css" onload="this.onload=null;this.rel='stylesheet'">
		<noscript><link href="/assets/css/aos.css" rel="stylesheet"></noscript>

		<script is:inline>
			// Check if running as PWA (standalone mode)
			if (window.matchMedia('(display-mode: standalone)').matches || 
				window.navigator.standalone === true) {
				// Redirect to login page when opened as PWA
				window.location.replace('/login');
			}
		</script>

		<!-- Load jQuery first so that page-specific inline scripts can use $ safely -->
		<script is:inline src="/assets/js/jquery.js"></script>
	</head>
	<body class="font-sans text-slate-600 antialiased overflow-x-hidden bg-slate-900">
		<!-- Google Tag Manager (noscript) -->
		{gtmId && (
			<noscript><iframe src={`https://www.googletagmanager.com/ns.html?id=${gtmId}`}
			height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
		)}
		<!-- End Google Tag Manager (noscript) -->

		<slot />
		
		<!-- Scripts (Non-blocking) -->
		<script is:inline src="/assets/js/aos.js"></script>

		<!-- Initialize Global Scripts -->
		<script is:inline>
			$(document).ready(function() {
				// Init AOS
				AOS.init({
					duration: 800,
					once: true,
					offset: 50
				});
			});
		</script>

		<!-- Analytics Event Tracking (pushes to GTM dataLayer) -->
		<script is:inline src="/assets/js/analytics.js"></script>
	</body>
</html>
