---
import '../styles/index.css';
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/sections/Hero.astro';
import Comparison from '../components/sections/Comparison.astro';
import TargetMarket from '../components/sections/TargetMarket.astro';
import Features from '../components/sections/Features.astro';
import Innovation from '../components/sections/Innovation.astro';
import Pricing from '../components/sections/Pricing.astro';
import AffiliateCTA from '../components/sections/AffiliateCTA.astro';

const variant = Astro.url.searchParams.get('variant')?.toUpperCase() as 'A' | 'B' | undefined;
---

<Layout 
    title="Jaripos — Aplikasi Kasir Pintar Paling Terjangkau untuk UMKM"
    description="Jaripos adalah aplikasi kasir pintar (Point of Sale / POS) berbasis AI terbaik dan paling terjangkau untuk UMKM di Indonesia. Kelola transaksi, stok barang, dan laporan keuangan bisnis Anda."
    keywords="aplikasi kasir, aplikasi kasir pintar, POS umkm, point of sales, kasir online, manajemen stok, jaripos, jari pos, jaropos"
>
    <Navbar />

    <!-- Main Content Wrapper for Footer Reveal Effect -->
    <main class="relative z-10 bg-white shadow-2xl">

        <!-- Hero & Header Wrapper with Light Geometric Mesh -->
        <div class="hero-light-wrapper">
            <div class="mesh-grid-light"></div>
            
            <Hero variant={variant} />
        </div>

        <!-- Problem vs Solution Section -->
        <Comparison />

        <!-- Target Market Section -->
        <TargetMarket />

        <!-- Features Section with Glassmorphism -->
        <Features variant={variant} />

        <!-- Innovation & Roadmap Section -->
        <Innovation />

        <!-- Pricing Section -->
        <Pricing variant={variant} />

        <!-- Affiliate CTA Section -->
        <AffiliateCTA variant={variant} />

    </main>

    <Footer />

    <!-- Floating WhatsApp Button -->
    <a 
        href="https://wa.me/6285875502569?text=Halo%2C%20saya%20tertarik%20dengan%20Jaripos" 
        target="_blank" 
        aria-label="Hubungi kami di WhatsApp" 
        class="fixed bottom-8 right-8 lg:bottom-12 lg:right-12 z-50 w-14 h-14 bg-[#25D366] hover:bg-[#20BA56] text-white rounded-full shadow-2xl flex items-center justify-center transition-all duration-300 hover:scale-110 hover:-translate-y-1 animate-whatsapp animate-float"
    >
        <i class="fab fa-whatsapp text-3xl"></i>
    </a>

    <style>
        @keyframes pulse-slow {
            0%, 100% { transform: scale(1); box-shadow: 0 10px 25px -5px rgba(37, 211, 102, 0.4); }
            50% { transform: scale(1.05); box-shadow: 0 20px 35px -5px rgba(37, 211, 102, 0.6); }
        }
        .animate-whatsapp {
            animation: pulse-slow 3s infinite ease-in-out;
        }
    </style>

    <!-- Page Specific Scripts -->
    <script is:inline>
        $(document).ready(function() {
            // Anchor Links Smooth Scrolling
            $.extend($.easing, {
                easeInOutExpo: function (x, t, b, c, d) {
                    if (t==0) return b;
                    if (t==d) return b+c;
                    if ((t/=d/2) < 1) return c/2 * Math.pow(2, 10 * (t - 1)) + b;
                    return c/2 * (-Math.pow(2, -10 * --t) + 2) + b;
                }
            });
        });
    </script>
</Layout>
