---
import AuthLayout from '../layouts/AuthLayout.astro';
---

<AuthLayout 
    title="Daftar Akun Kasir Pintar Jaripos | AI-powered POS"
    description="Daftar akun Jaripos gratis sekarang juga. Kelola operasional bisnis Anda dengan aplikasi kasir pintar terintegrasi AI, pencatatan transaksi mudah, manajemen stok, dan laporan keuangan instan."
    robots="index, follow"
>
    <!-- HTML Meta Refresh Redirect for SEO & Browsers without JS -->
    <meta http-equiv="refresh" content="0;url=https://app.jaripos.com/register" slot="head" />

    <div class="w-full max-w-md bg-white rounded-3xl shadow-2xl border border-slate-100 p-10 m-4 text-center relative overflow-hidden">
        <!-- Background decorative blur -->
        <div class="absolute -top-10 -right-10 w-32 h-32 bg-cyan-500/10 rounded-full blur-2xl"></div>
        <div class="absolute -bottom-10 -left-10 w-32 h-32 bg-brand-500/10 rounded-full blur-2xl"></div>
        
        <div class="relative z-10">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-gradient-to-br from-brand-500 to-brand-600 rounded-2xl text-white font-black text-4xl shadow-xl shadow-brand-500/30 mb-6 animate-pulse">
                J
            </div>
            <h1 class="text-2xl font-black text-slate-900 tracking-tight">Membuat Pendaftaran</h1>
            <p class="text-slate-500 text-sm mt-3 leading-relaxed">Harap tunggu sebentar, kami sedang mengarahkan Anda ke halaman pendaftaran akun Jaripos...</p>
            
            <!-- Sleek CSS Spinner -->
            <div class="flex justify-center my-8">
                <div class="relative w-12 h-12">
                    <div class="absolute inset-0 border-4 border-slate-100 rounded-full"></div>
                    <div class="absolute inset-0 border-4 border-brand-500 border-t-transparent rounded-full animate-spin"></div>
                </div>
            </div>

            <p class="text-xs text-slate-400">
                Tidak teralihkan otomatis? <a href="https://app.jaripos.com/register" class="font-bold text-brand-600 hover:text-brand-700 underline">Klik di sini</a>
            </p>
        </div>
    </div>

    <!-- Client-side Redirect Script -->
    <script is:inline>
        window.location.href = "https://app.jaripos.com/register";
    </script>
</AuthLayout>
