---
import '../styles/index.css';
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
    title="Program Kemitraan Afiliasi JARIPOS - Komisi Melimpah & Transparan" 
    description="Gabung program afiliasi JARIPOS secara gratis. Bagikan link referral Anda dan nikmati komisi berkelanjutan dari setiap langganan pengguna kasir online JARIPOS."
>
    <!-- Navbar is fixed and handled globally -->
    <Navbar isAffiliatePage={true} />

    <!-- Main Content Wrapper -->
    <main class="relative z-10 bg-white shadow-2xl">
        
        <!-- Hero Section with Light Mesh Grid -->
        <div class="hero-light-wrapper border-b border-slate-100">
            <div class="mesh-grid-light"></div>
            
            <section class="pt-40 pb-20 lg:pt-52 lg:pb-28 relative z-10">
                <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center flex flex-col items-center">
                    <h1 data-aos="fade-up" data-aos-delay="100" class="text-4xl md:text-6xl font-extrabold text-[#121417] leading-tight tracking-tight mb-6">
                        Rekomendasikan JARIPOS, <br/>
                        <span class="text-[#1f5aa2]">Dapatkan Komisi 20%!</span>
                    </h1>
                    
                    <p data-aos="fade-up" data-aos-delay="200" class="text-lg text-slate-600 mb-10 max-w-2xl leading-relaxed">
                        Dapatkan komisi 20% untuk setiap pembelian atau perpanjangan paket menggunakan voucher/kode referal Anda dengan membagikan solusi kasir pintar JARIPOS ke rekan bisnis atau komunitas UMKM Anda.
                    </p>
                    
                    <div data-aos="fade-up" data-aos-delay="300" class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto justify-center">
                        <a 
                            href="https://app.jaripos.com/affiliate/register" 
                            target="_blank" 
                            rel="noopener noreferrer" 
                            class="group inline-flex items-center justify-center rounded-full px-8 py-4 font-bold text-white bg-[#1f5aa2] hover:bg-[#164075] active:scale-95 transition-colors duration-300 ease-out shadow-lg shadow-[#1f5aa2]/20 gap-2"
                        >
                            <span>Gabung Afiliasi Sekarang (Gratis)</span>
                            <svg class="h-5 w-5 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
                        </a>
                    </div>
                </div>
            </section>
        </div>

        <!-- How It Works Section -->
        <section id="how-it-works" class="py-16 md:py-24 bg-slate-50 relative overflow-hidden">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
                <div class="text-center mb-16" data-aos="fade-up">
                    <h2 class="text-3xl md:text-5xl font-black text-slate-900 mb-4 tracking-tight">Bagaimana Cara Kerjanya?</h2>
                    <p class="text-slate-500 text-sm md:text-base max-w-xl mx-auto">Mulai menghasilkan pendapatan tambahan dalam hitungan menit dengan alur kerja yang sederhana.</p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
                    <!-- Step 1 -->
                    <div data-aos="fade-up" data-aos-delay="100" class="bg-white rounded-3xl p-8 border border-slate-100 shadow-sm relative group hover:shadow-md transition duration-300">
                        <div class="w-12 h-12 rounded-2xl bg-[#1f5aa2]/10 flex items-center justify-center text-[#1f5aa2] font-extrabold text-lg mb-6">1</div>
                        <h3 class="text-xl font-bold text-slate-900 mb-3">Daftar Instan</h3>
                        <p class="text-slate-500 text-sm leading-relaxed">
                            Registrasi akun Anda secara gratis di portal afiliasi kami dalam 2 menit. Anda akan langsung mendapatkan link referral unik Anda sendiri.
                        </p>
                    </div>

                    <!-- Step 2 -->
                    <div data-aos="fade-up" data-aos-delay="200" class="bg-white rounded-3xl p-8 border border-slate-100 shadow-sm relative group hover:shadow-md transition duration-300">
                        <div class="w-12 h-12 rounded-2xl bg-[#1f5aa2]/10 flex items-center justify-center text-[#1f5aa2] font-extrabold text-lg mb-6">2</div>
                        <h3 class="text-xl font-bold text-slate-900 mb-3">Bagikan Link & Voucher</h3>
                        <p class="text-slate-500 text-sm leading-relaxed">
                            Promosikan link referral atau kode voucher JARIPOS Anda ke rekan bisnis, komunitas kuliner/retail, atau lewat media sosial Anda.
                        </p>
                    </div>

                    <!-- Step 3 -->
                    <div data-aos="fade-up" data-aos-delay="300" class="bg-white rounded-3xl p-8 border border-slate-100 shadow-sm relative group hover:shadow-md transition duration-300">
                        <div class="w-12 h-12 rounded-2xl bg-[#1f5aa2]/10 flex items-center justify-center text-[#1f5aa2] font-extrabold text-lg mb-6">3</div>
                        <h3 class="text-xl font-bold text-slate-900 mb-3">Dapatkan Komisi 20%</h3>
                        <p class="text-slate-500 text-sm leading-relaxed">
                            Terima komisi 20% setiap kali ada transaksi pembelian baru atau perpanjangan paket yang menggunakan kode referal/voucher Anda.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Benefits Section -->
        <section id="benefits" class="py-16 md:py-24 bg-white relative overflow-hidden">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
                <div class="text-center mb-16" data-aos="fade-up">
                    <h2 class="text-3xl md:text-5xl font-black text-slate-900 mb-4 tracking-tight">Mengapa Memilih JARIPOS?</h2>
                    <p class="text-slate-500 text-sm md:text-base max-w-xl mx-auto">Kami menghargai kontribusi Anda dengan komisi terbaik dan transparansi penuh.</p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
                    <!-- Benefit 1 -->
                    <div data-aos="fade-up" class="flex flex-col gap-3 p-6 bg-slate-50/50 rounded-2xl hover:bg-slate-50 transition duration-300">
                        <div class="w-10 h-10 rounded-xl bg-[#1f5aa2]/10 text-[#1f5aa2] flex items-center justify-center text-lg shrink-0 border border-[#1f5aa2]/20">
                            <i class="fas fa-percent"></i>
                        </div>
                        <div>
                            <h3 class="text-lg font-bold text-slate-900 mb-1">Komisi 20% Berkelanjutan</h3>
                            <p class="text-slate-500 text-sm leading-relaxed">
                                Dapatkan komisi sebesar 20% dari setiap pembelian baru maupun perpanjangan paket aktif pengguna yang menggunakan referal Anda.
                            </p>
                        </div>
                    </div>

                    <!-- Benefit 2 -->
                    <div data-aos="fade-up" class="flex flex-col gap-3 p-6 bg-slate-50/50 rounded-2xl hover:bg-slate-50 transition duration-300">
                        <div class="w-10 h-10 rounded-xl bg-[#1f5aa2]/10 text-[#1f5aa2] flex items-center justify-center text-lg shrink-0 border border-[#1f5aa2]/20">
                            <i class="fas fa-chart-line"></i>
                        </div>
                        <div>
                            <h3 class="text-lg font-bold text-slate-900 mb-1">Dashboard Real-Time</h3>
                            <p class="text-slate-500 text-sm leading-relaxed">
                                Lacak klik link referral, daftar pengguna uji coba, hingga transaksi pembayaran sukses secara transparan di dashboard Anda.
                            </p>
                        </div>
                    </div>

                    <!-- Benefit 3 -->
                    <div data-aos="fade-up" class="flex flex-col gap-3 p-6 bg-slate-50/50 rounded-2xl hover:bg-slate-50 transition duration-300">
                        <div class="w-10 h-10 rounded-xl bg-[#1f5aa2]/10 text-[#1f5aa2] flex items-center justify-center text-lg shrink-0 border border-[#1f5aa2]/20">
                            <i class="fas fa-wallet"></i>
                        </div>
                        <div>
                            <h3 class="text-lg font-bold text-slate-900 mb-1">Pencairan Dana Bulanan</h3>
                            <p class="text-slate-500 text-sm leading-relaxed">
                                Akumulasi komisi dicairkan secara terjadwal setiap bulan langsung ke rekening bank lokal pilihan Anda tanpa biaya penarikan tambahan.
                            </p>
                        </div>
                    </div>

                </div>
            </div>
        </section>

        <!-- FAQ Section -->
        <section id="faq" class="py-16 md:py-24 bg-slate-50 relative overflow-hidden border-t border-slate-100">
            <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
                <div class="text-center mb-16" data-aos="fade-up">
                    <h2 class="text-3xl md:text-5xl font-black text-slate-900 mb-4 tracking-tight">Pertanyaan Umum (FAQ)</h2>
                    <p class="text-slate-500 text-sm md:text-base">Punya pertanyaan seputar program afiliasi kami? Cari jawabannya di bawah ini.</p>
                </div>

                <div class="space-y-4 max-w-3xl mx-auto">
                    <!-- FAQ 1 -->
                    <details data-aos="fade-up" class="group bg-white rounded-2xl border border-slate-200/80 overflow-hidden [&_summary::-webkit-details-marker]:hidden">
                        <summary class="flex justify-between items-center p-6 text-slate-900 font-bold text-base md:text-lg cursor-pointer select-none">
                            <span>Apakah program afiliasi JARIPOS ini berbayar?</span>
                            <span class="transition-transform duration-300 group-open:rotate-180 text-slate-400">
                                <i class="fas fa-chevron-down text-sm"></i>
                            </span>
                        </summary>
                        <div class="px-6 pb-6 text-slate-500 text-sm md:text-base leading-relaxed border-t border-slate-50 pt-4">
                            Sama sekali tidak. Pendaftaran program afiliasi JARIPOS 100% gratis selamanya tanpa ada biaya awal maupun biaya bulanan.
                        </div>
                    </details>

                    <!-- FAQ 2 -->
                    <details data-aos="fade-up" class="group bg-white rounded-2xl border border-slate-200/80 overflow-hidden [&_summary::-webkit-details-marker]:hidden">
                        <summary class="flex justify-between items-center p-6 text-slate-900 font-bold text-base md:text-lg cursor-pointer select-none">
                            <span>Bagaimana cara melacak penjualan dari rekomendasi saya?</span>
                            <span class="transition-transform duration-300 group-open:rotate-180 text-slate-400">
                                <i class="fas fa-chevron-down text-sm"></i>
                            </span>
                        </summary>
                        <div class="px-6 pb-6 text-slate-500 text-sm md:text-base leading-relaxed border-t border-slate-50 pt-4">
                            Setiap pendaftaran dan pembayaran dilacak menggunakan link referral unik yang Anda bagikan. Segera setelah calon pelanggan mendaftar melalui link tersebut, sistem akan mencatat akun tersebut di bawah akun afiliasi Anda.
                        </div>
                    </details>

                    <!-- FAQ 3 -->
                    <details data-aos="fade-up" class="group bg-white rounded-2xl border border-slate-200/80 overflow-hidden [&_summary::-webkit-details-marker]:hidden">
                        <summary class="flex justify-between items-center p-6 text-slate-900 font-bold text-base md:text-lg cursor-pointer select-none">
                            <span>Kapan komisi ditransfer dan berapakah penarikan minimumnya?</span>
                            <span class="transition-transform duration-300 group-open:rotate-180 text-slate-400">
                                <i class="fas fa-chevron-down text-sm"></i>
                            </span>
                        </summary>
                        <div class="px-6 pb-6 text-slate-500 text-sm md:text-base leading-relaxed border-t border-slate-50 pt-4">
                            Komisi akan diakumulasikan dan ditransfer ke rekening bank terdaftar Anda pada minggu pertama setiap bulannya, dengan batas penarikan minimum saldo komisi yang ditentukan dalam portal dashboard afiliasi Anda.
                        </div>
                    </details>

                    <!-- FAQ 4 -->
                    <details data-aos="fade-up" class="group bg-white rounded-2xl border border-slate-200/80 overflow-hidden [&_summary::-webkit-details-marker]:hidden">
                        <summary class="flex justify-between items-center p-6 text-slate-900 font-bold text-base md:text-lg cursor-pointer select-none">
                            <span>Apakah saya harus menjadi pengguna JARIPOS untuk mendaftar?</span>
                            <span class="transition-transform duration-300 group-open:rotate-180 text-slate-400">
                                <i class="fas fa-chevron-down text-sm"></i>
                            </span>
                        </summary>
                        <div class="px-6 pb-6 text-slate-500 text-sm md:text-base leading-relaxed border-t border-slate-50 pt-4">
                            Tidak wajib. Namun, kami sangat merekomendasikan Anda untuk mencoba menggunakan paket gratis JARIPOS terlebih dahulu agar Anda dapat menjelaskan kelebihan fitur-fiturnya secara meyakinkan kepada calon pengguna.
                        </div>
                    </details>
                </div>
            </div>
        </section>

        <!-- Final CTA Section -->
        <section class="py-16 md:py-20 bg-white relative overflow-hidden">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
                <div data-aos="zoom-in" class="bg-gradient-to-r from-slate-950 via-slate-900 to-indigo-950 rounded-2xl p-8 md:p-12 text-white relative overflow-hidden shadow-2xl border border-[#dfba6b]/30 flex flex-col md:flex-row items-center justify-between gap-8">
                    <div class="absolute -right-10 -top-10 w-40 h-40 bg-[#dfba6b]/5 rounded-full blur-[40px] pointer-events-none"></div>
                    
                    <div class="space-y-2 relative z-10 w-full md:text-left text-center">
                        <h2 class="text-2xl md:text-3xl font-black text-white">Siap Mendapatkan Penghasilan Tambahan?</h2>
                        <p class="text-slate-400 text-sm md:text-base max-w-xl">
                            Gabung program kemitraan kami sekarang juga dan rasakan kemudahan menghasilkan pendapatan pasif bulanan yang menjanjikan.
                        </p>
                    </div>
                    
                    <a 
                        href="https://app.jaripos.com/affiliate/register" 
                        target="_blank" 
                        rel="noopener noreferrer" 
                        class="group w-full md:w-auto text-center px-8 py-4 rounded-full bg-gradient-to-r from-[#dfba6b] to-[#c29c47] hover:brightness-110 active:scale-95 text-slate-950 font-extrabold text-base transition-all duration-300 ease-out shadow-lg shrink-0 relative z-10 cursor-pointer inline-flex items-center justify-center gap-2"
                    >
                        <span class="hidden md:inline">Daftar Kemitraan Sekarang</span>
                        <span class="inline md:hidden">Daftar Sekarang</span>
                        <i class="fas fa-arrow-right text-xs transition-transform duration-300 group-hover:translate-x-1"></i>
                    </a>
                </div>
            </div>
        </section>
        
    </main>

    <Footer />
</Layout>
