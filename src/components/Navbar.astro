---
interface Props {
    isAffiliatePage?: boolean;
}
const { isAffiliatePage = false } = Astro.props;
---
{!isAffiliatePage && (
<!-- Affiliate Announcement Banner -->
<div id="affiliate-banner" class="relative w-full z-[60] bg-gradient-to-r from-[#c5a059] via-[#f3e7c4] to-[#b28d46] text-slate-950 py-2.5 px-4 flex items-center justify-between transition-all duration-300">
    <div class="flex items-center justify-between md:justify-center gap-8 w-full pr-8 pl-1 md:pr-0 md:pl-0 max-w-7xl mx-auto">
        <span class="flex-1 md:flex-initial text-left md:text-center text-[11px] sm:text-xs md:text-sm font-bold text-slate-950 leading-snug flex items-center gap-1.5">
            <span class="hidden md:inline mt-0.5">💰</span>
            <span>Gabung program kemitraan <span class="font-extrabold text-slate-950">afiliasi JARIPOS</span> & dapatkan komisi menarik!</span>
        </span>
        <a 
            href="/affiliate" 
            class="bg-slate-950 text-white hover:bg-slate-900 px-3 py-1.5 rounded-full text-[10px] sm:text-xs font-black transition duration-150 shrink-0 inline-flex items-center gap-1 shadow-sm"
        >
            Daftar<span class="hidden sm:inline"> Sekarang</span> <i class="fas fa-arrow-right text-[8px] sm:text-[10px]"></i>
        </a>
    </div>
    <button 
        id="close-banner" 
        class="absolute right-3 text-slate-950/80 hover:text-slate-950 transition duration-150 p-1 cursor-pointer focus:outline-none flex items-center justify-center" 
        aria-label="Tutup banner"
    >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" />
        </svg>
    </button>
</div>
)}

<nav id="navbar" class="fixed top-0 left-0 w-full z-50 transition-all duration-500 ease-in-out bg-transparent border-b border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div id="navbar-container" class="flex justify-between items-center h-28 transition-all duration-500">
            <!-- Logo -->
            <a href="/" class="flex-shrink-0 flex items-center cursor-pointer transition-transform hover:scale-105">
                <img src="/JARI-BLACK.png" alt="Jaripos Logo" class="h-8 md:h-10 w-auto logo-black transition-opacity duration-500" />
                <img src="/JARI-WHITE.png" alt="Jaripos Logo" class="h-8 md:h-10 w-auto logo-white transition-opacity duration-500" />
            </a>

            <style>
                /* Override default transition-all on top to prevent lag while scrolling */
                #navbar {
                    transition: background-color 0.5s ease-in-out, border-color 0.5s ease-in-out, box-shadow 0.5s ease-in-out !important;
                    will-change: top, background-color;
                }

                /* Stacking context & Display Overrides */
                @media (max-width: 767px) {
                    .desktop-menu-container {
                        display: none !important;
                    }
                    .mobile-menu-btn-container {
                        display: flex !important;
                        align-items: center !important;
                        z-index: 50 !important;
                    }
                }
                @media (min-width: 768px) {
                    .desktop-menu-container {
                        display: flex !important;
                        align-items: center !important;
                    }
                    .mobile-menu-btn-container {
                        display: none !important;
                    }
                }

                /* Logo display toggle */
                #navbar:not(.nav-scrolled) .logo-white { display: none !important; }
                #navbar:not(.nav-scrolled) .logo-black { display: block !important; }
                
                #navbar.nav-scrolled .logo-white { display: block !important; }
                #navbar.nav-scrolled .logo-black { display: none !important; }
                
                /* Dynamic theme overrides for dark sections if any */
                #navbar.nav-dark .logo-black { display: none !important; }
                #navbar.nav-dark .logo-white { display: block !important; }

                /* Solid mobile menu background when open */
                #navbar.mobile-menu-open {
                    background-color: #ffffff !important;
                    border-bottom: 1px solid #e2e8f0 !important;
                    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05) !important;
                }
                #navbar.mobile-menu-open.nav-scrolled {
                    background-color: #0f172a !important;
                    border-bottom: 1px solid rgba(255, 255, 255, 0.1) !important;
                }
                
                /* Logo overrides when mobile menu is open in non-scrolled mode */
                #navbar.mobile-menu-open:not(.nav-scrolled) .logo-black { display: block !important; }
                #navbar.mobile-menu-open:not(.nav-scrolled) .logo-white { display: none !important; }

                /* Mobile Hamburger Button Color Enforcement */
                #mobile-menu-btn {
                    color: #1e293b !important; /* slate-800/900 */
                    display: flex !important;
                    align-items: center !important;
                    justify-content: center !important;
                    z-index: 50 !important;
                }
                #navbar.nav-scrolled #mobile-menu-btn {
                    color: #ffffff !important;
                }
                #navbar.mobile-menu-open:not(.nav-scrolled) #mobile-menu-btn {
                    color: #1e293b !important;
                }
                #mobile-menu-btn svg {
                    stroke: currentColor !important;
                    width: 32px !important;
                    height: 32px !important;
                }
                #mobile-menu-btn svg.hidden {
                    display: none !important;
                }
                #mobile-menu-btn svg:not(.hidden) {
                    display: block !important;
                }
            </style>

            <!-- Desktop Menu -->
            <div class="desktop-menu-container space-x-8">
                {isAffiliatePage ? (
                    <>
                        <a href="#how-it-works" class="nav-link text-slate-900 hover:text-cyan-brand font-medium transition duration-300 hover:-translate-y-0.5">Cara Kerja</a>
                        <a href="#benefits" class="nav-link text-slate-900 hover:text-cyan-brand font-medium transition duration-300 hover:-translate-y-0.5">Keuntungan</a>
                        <a href="#faq" class="nav-link text-slate-900 hover:text-cyan-brand font-medium transition duration-300 hover:-translate-y-0.5">FAQ</a>
                        <a href="https://app.jaripos.com/affiliate/register" target="_blank" rel="noopener noreferrer" data-track="nav-cta-desktop" class="group relative inline-flex items-center justify-center overflow-hidden rounded-full px-6 py-2.5 font-semibold text-white bg-cyan-brand duration-300 hover:brightness-110 shadow-lg shadow-cyan-500/20">
                            <div class="absolute inset-0 flex h-full w-full justify-center [transform:skew(-12deg)_translateX(-100%)] group-hover:duration-1000 group-hover:[transform:skew(-12deg)_translateX(100%)]">
                                <div class="relative h-full w-8 bg-white/20"></div>
                            </div>
                            <span class="relative">Daftar Afiliasi</span>
                        </a>
                    </>
                ) : (
                    <>
                        <a href="/#comparison" class="nav-link text-slate-900 hover:text-cyan-brand font-medium transition duration-300 hover:-translate-y-0.5">Kenapa JARIPOS?</a>
                        <a href="/#target-market" class="nav-link text-slate-900 hover:text-cyan-brand font-medium transition duration-300 hover:-translate-y-0.5">Cocok untuk Siapa?</a>
                        <a href="/#features" class="nav-link text-slate-900 hover:text-cyan-brand font-medium transition duration-300 hover:-translate-y-0.5">Fitur</a>
                        <a href="/#pricing" class="nav-link text-slate-900 hover:text-cyan-brand font-medium transition duration-300 hover:-translate-y-0.5">Harga</a>
                        <a href="https://app.jaripos.com" data-track="nav-login" class="nav-link text-slate-900 hover:text-cyan-brand font-medium transition duration-300 hover:-translate-y-0.5">Masuk</a>
                        <a href="https://app.jaripos.com/register" data-track="nav-cta-desktop" class="group relative inline-flex items-center justify-center overflow-hidden rounded-full px-6 py-2.5 font-semibold text-white bg-cyan-brand duration-300 hover:brightness-110 shadow-lg shadow-cyan-500/20">
                            <div class="absolute inset-0 flex h-full w-full justify-center [transform:skew(-12deg)_translateX(-100%)] group-hover:duration-1000 group-hover:[transform:skew(-12deg)_translateX(100%)]">
                                <div class="relative h-full w-8 bg-white/20"></div>
                            </div>
                            <span class="relative">Coba Gratis</span>
                        </a>
                    </>
                )}
            </div>

            <!-- Mobile Menu Button -->
            <div class="mobile-menu-btn-container">
                <button id="mobile-menu-btn" aria-label="Menu" class="focus:outline-none p-2 transition-all duration-300">
                    <!-- Hamburger Icon -->
                    <svg id="hamburger-icon" class="transition-all duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                    </svg>
                    <!-- Close (X) Icon -->
                    <svg id="close-icon" class="hidden transition-all duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                </button>
            </div>
        </div>
    </div>
    
    <!-- Mobile Menu Panel -->
    <div id="mobile-menu" class="hidden md:hidden absolute w-full bg-white border-b border-slate-200 shadow-xl transition-colors duration-500">
        <div class="px-4 pt-2 pb-6 space-y-2">
            {isAffiliatePage ? (
                <>
                    <a href="#how-it-works" class="mobile-nav-link block px-3 py-3 rounded-md text-base font-medium text-slate-600 hover:text-brand-600 hover:bg-slate-50">Cara Kerja</a>
                    <a href="#benefits" class="mobile-nav-link block px-3 py-3 rounded-md text-base font-medium text-slate-600 hover:text-brand-600 hover:bg-slate-50">Keuntungan</a>
                    <a href="#faq" class="mobile-nav-link block px-3 py-3 rounded-md text-base font-medium text-slate-600 hover:text-brand-600 hover:bg-slate-50">FAQ</a>
                    <a href="https://app.jaripos.com/affiliate/register" target="_blank" rel="noopener noreferrer" data-track="nav-cta-mobile" class="block w-full text-center mt-4 px-6 py-3 rounded-lg text-white bg-cyan-brand font-bold shadow-md">Daftar Afiliasi</a>
                </>
            ) : (
                <>
                    <a href="/#comparison" class="mobile-nav-link block px-3 py-3 rounded-md text-base font-medium text-slate-600 hover:text-brand-600 hover:bg-slate-50">Kenapa JARIPOS?</a>
                    <a href="/#target-market" class="mobile-nav-link block px-3 py-3 rounded-md text-base font-medium text-slate-600 hover:text-brand-600 hover:bg-slate-50">Cocok untuk Siapa?</a>
                    <a href="/#features" class="mobile-nav-link block px-3 py-3 rounded-md text-base font-medium text-slate-600 hover:text-brand-600 hover:bg-slate-50">Fitur</a>
                    <a href="/#pricing" class="mobile-nav-link block px-3 py-3 rounded-md text-base font-medium text-slate-600 hover:text-brand-600 hover:bg-slate-50">Harga</a>
                    <a href="https://app.jaripos.com/register" data-track="nav-cta-mobile" class="block w-full text-center mt-4 px-6 py-3 rounded-lg text-white bg-cyan-brand font-bold shadow-md">Coba Gratis Sekarang</a>
                </>
            )}
        </div>
    </div>
</nav>

<script is:inline>
    function initNavbar() {
        const navbar = document.getElementById('navbar');
        const mobileMenuBtn = document.getElementById('mobile-menu-btn');
        const mobileMenu = document.getElementById('mobile-menu');
        const hamburgerIcon = document.getElementById('hamburger-icon');
        const closeIcon = document.getElementById('close-icon');
        const navbarContainer = document.getElementById('navbar-container');
        const banner = document.getElementById('affiliate-banner');
        const closeBannerBtn = document.getElementById('close-banner');

        if (!navbar) return;

        function getBannerHeight() {
            if (banner && banner.style.display !== 'none') {
                return banner.offsetHeight;
            }
            return 0;
        }

        function updateNavbar() {
            const scrollPos = window.scrollY || window.pageYOffset || document.documentElement.scrollTop;
            const bannerHeight = getBannerHeight();
            
            // Position of Navbar
            if (bannerHeight > 0) {
                if (scrollPos < bannerHeight) {
                    navbar.style.top = `${bannerHeight - scrollPos - 1}px`;
                } else {
                    navbar.style.top = '0px';
                }
                document.documentElement.style.scrollPaddingTop = `${80 + bannerHeight}px`;
            } else {
                navbar.style.top = '0px';
                document.documentElement.style.scrollPaddingTop = '80px';
            }
            
            // Handle Scroll Background
            if (scrollPos > 40) {
                navbar.classList.add('nav-scrolled');
                navbar.classList.remove('bg-transparent', 'border-white/10');
                
                // Update text colors for dark background (scrolled)
                navbar.querySelectorAll('.nav-link').forEach(el => {
                    el.classList.remove('text-slate-900');
                    el.classList.add('text-white');
                });

                if (navbarContainer) {
                    navbarContainer.classList.remove('h-28');
                    navbarContainer.classList.add('h-20');
                }
            } else {
                navbar.classList.remove('nav-scrolled');
                navbar.classList.add('bg-transparent', 'border-white/10');
                
                // Update text colors for light background (idle)
                navbar.querySelectorAll('.nav-link').forEach(el => {
                    el.classList.remove('text-white');
                    el.classList.add('text-slate-900');
                });

                if (navbarContainer) {
                    navbarContainer.classList.remove('h-20');
                    navbarContainer.classList.add('h-28');
                }
            }
        }
        
        // Handle closing banner
        if (closeBannerBtn && banner) {
            closeBannerBtn.addEventListener('click', () => {
                banner.style.display = 'none';
                updateNavbar();
            });
        }
        
        window.addEventListener('scroll', updateNavbar, { passive: true });
        window.addEventListener('touchmove', updateNavbar, { passive: true });
        window.addEventListener('resize', updateNavbar, { passive: true });
        updateNavbar();

        // Mobile Menu Toggle using pure Vanilla JS
        if (mobileMenuBtn && mobileMenu) {
            let menuOpen = false;
            mobileMenuBtn.addEventListener('click', () => {
                menuOpen = !menuOpen;
                if (menuOpen) {
                    mobileMenu.classList.remove('hidden');
                    navbar.classList.add('mobile-menu-open');
                    if (hamburgerIcon) hamburgerIcon.classList.add('hidden');
                    if (closeIcon) closeIcon.classList.remove('hidden');
                } else {
                    mobileMenu.classList.add('hidden');
                    navbar.classList.remove('mobile-menu-open');
                    if (hamburgerIcon) hamburgerIcon.classList.remove('hidden');
                    if (closeIcon) closeIcon.classList.add('hidden');
                }
            });

            // Close menu on link click
            mobileMenu.querySelectorAll('a').forEach(link => {
                link.addEventListener('click', () => {
                    menuOpen = false;
                    mobileMenu.classList.add('hidden');
                    navbar.classList.remove('mobile-menu-open');
                    if (hamburgerIcon) hamburgerIcon.classList.remove('hidden');
                    if (closeIcon) closeIcon.classList.add('hidden');
                });
            });
        }
    }

    // Run robustly whether DOM is already loaded or still loading
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initNavbar);
    } else {
        initNavbar();
    }
</script>
