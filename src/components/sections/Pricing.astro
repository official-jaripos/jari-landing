---
---
<section id="pricing" class="py-24 bg-white relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(#e5e7eb_1px,transparent_1px)] [background-size:16px_16px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_50%,#000_70%,transparent_100%)] opacity-30"></div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="text-center mb-16" data-aos="fade-up">
            <h2 class="text-3xl md:text-5xl font-black text-slate-900 mb-4 tracking-tight">Investasi Receh, Untung Gede</h2>
            <p class="text-slate-500 text-md md:text-xl max-w-2xl mx-auto">Semua pemilik bisnis berhak sukses. Mulai perjalanan Anda tanpa biaya.</p>
        </div>

        <div class="flex flex-col lg:flex-row gap-12 max-w-6xl mx-auto items-start">
            
            <!-- PRIORITY: Paket Kelingking (The only entry point) -->
            <div data-aos="fade-right" class="w-full lg:w-3/5 bg-slate-900 rounded-3xl md:rounded-[2.5rem] p-6 md:p-12 border border-slate-800 shadow-2xl relative overflow-hidden group">
                <!-- Glowing Decoration -->
                <div class="absolute -top-24 -left-24 w-64 h-64 bg-brand-600/20 rounded-full blur-3xl group-hover:bg-brand-600/30 transition-all duration-700"></div>
                
                <div class="relative z-10">
                    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-brand-600 text-white text-[10px] font-bold mb-8 uppercase tracking-[0.2em] shadow-lg shadow-brand-500/20">
                        Prioritas Utama
                    </div>
                    
                    <h3 class="text-4xl md:text-5xl font-black text-white mb-2">Paket Kelingking</h3>
                    <p class="text-brand-400 text-sm font-semibold mb-4">Gratis 14 Hari, Akses Penuh</p>
                    <p class="text-slate-400 text-lg mb-10 max-w-md leading-relaxed">Nikmati akses penuh selama 14 hari untuk merasakan bagaimana Jaripos mengelola tokomu secara otomatis.</p>
                    
                    <div class="flex flex-col sm:flex-row sm:items-baseline mb-10">
                        <span class="text-5xl md:text-7xl font-black text-white">Gratis</span>
                        <span class="text-brand-400 sm:ml-3 text-lg md:text-xl font-medium mt-2 sm:mt-0">/ 14 Hari Trial</span>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
                        {[
                            'Akses Semua Fitur Utama',
                            'Input Produk Unlimited',
                            'Laporan Penjualan Realtime',
                            'Manajemen Stok Dasar',
                            'Multi-Platform (Web & HP)',
                            'Dukungan Chat Komunitas'
                        ].map((item) => (
                            <div class="flex items-center gap-3 text-slate-300">
                                <div class="flex-shrink-0 w-6 h-6 rounded-full bg-brand-500/10 flex items-center justify-center">
                                    <svg class="w-3.5 h-3.5 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                                </div>
                                <span class="text-sm md:text-base font-medium">{item}</span>
                            </div>
                        ))}
                    </div>

                    <a href="https://app.jaripos.com/register" data-track="pricing-cta-pro" class="group relative inline-flex w-full md:w-auto items-center justify-center overflow-hidden rounded-2xl bg-white px-8 md:px-12 py-5 font-black text-slate-900 shadow-xl duration-300 hover:scale-[1.03] hover:shadow-white/10">
                        <span class="relative text-lg whitespace-nowrap text-center">Coba Gratis Sekarang</span>
                    </a>
                    <p class="mt-6 text-slate-500 text-xs md:text-sm flex items-center gap-2">
                        <svg class="w-4 h-4 text-brand-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                        Tanpa biaya pendaftaran & kartu kredit
                    </p>
                </div>
            </div>

            <!-- SECONDARY: Informasi Upgrade (No Button) -->
            <div data-aos="fade-left" class="w-full lg:w-2/5 flex flex-col pt-4">
                <div class="bg-slate-50 rounded-[2rem] p-8 border border-slate-200">
                    <h3 class="text-2xl font-bold text-slate-900 mb-1">Paket Jempol</h3>
                    <p class="text-brand-500 text-xs font-semibold mb-2">Langganan Bulanan / Tahunan</p>
                    <p class="text-slate-500 text-sm mb-8">Setelah masa trial berakhir, Anda bisa upgrade ke Paket Jempol di dalam panel dashboard.</p>
                    
                    <!-- Sizing/Tier Info -->
                    <div class="space-y-4 mb-8">
                        {[
                            { label: 'Langganan 1 Bulan', price: '45.000', sub: '/ bulan' },
                            { label: 'Langganan 3 Bulan', price: '40.000', sub: '/ bulan' },
                            { label: 'Langganan 6 Bulan', price: '35.000', sub: '/ bulan' },
                            { label: 'Langganan 1 Tahun', price: '30.000', sub: '/ bulan', highlight: true }
                        ].map((tier) => (
                            <div class={`flex items-center justify-between p-4 rounded-2xl border ${tier.highlight ? 'bg-brand-50 border-brand-200 ring-1 ring-brand-200' : 'bg-white border-slate-100'}`}>
                                <span class={`text-sm font-bold ${tier.highlight ? 'text-brand-700' : 'text-slate-600'}`}>{tier.label}</span>
                                <div class="text-right">
                                    <span class={`text-lg font-black ${tier.highlight ? 'text-brand-600' : 'text-slate-900'}`}>{tier.price}</span>
                                    <span class="text-[10px] text-slate-400 block -mt-1">{tier.sub}</span>
                                </div>
                            </div>
                        ))}
                    </div>

                    <div class="pt-6 border-t border-slate-200">
                        <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-4">Keunggulan Pro:</p>
                        <ul class="space-y-3">
                            {['Manajemen Stok & Inventori', 'Laporan Laba/Rugi Realtime', 'Manajemen Pelanggan', 'Multi-User & Hak Akses Cabang'].map((feat) => (
                                <li class="flex items-start gap-2 text-xs text-slate-600">
                                    <svg class="w-3.5 h-3.5 text-brand-500 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                                    <span>{feat}</span>
                                </li>
                            ))}
                        </ul>
                    </div>
                </div>
                

            </div>

        </div>
    </div>
</section>
