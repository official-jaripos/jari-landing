---
---
<section id="pricing" class="py-24 bg-white relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="text-center mb-16" data-aos="fade-up">
            <h2 class="text-3xl md:text-5xl font-black font-display text-slate-900 mb-4 tracking-tight">Investasi Terjangkau, Operasional Lancar</h2>
            <p class="text-slate-600 text-base md:text-lg max-w-2xl mx-auto">Mulai perjalanan digitalisasi usaha Anda tanpa biaya tersembunyi. Pilih paket sesuai skala bisnis.</p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 max-w-6xl mx-auto items-stretch">
            
            <!-- LEFT: Paket Jempol (Premium Entry via Trial) - White Card with #1f5aa2 Border & Button -->
            <div data-aos="fade-right" class="w-full lg:col-span-7 bg-white rounded-3xl md:rounded-[2.5rem] p-8 md:p-10 border-2 border-[#1f5aa2] shadow-2xl transition-all duration-300 flex flex-col justify-between relative overflow-hidden">
                
                <div class="relative z-10">
                    <div class="flex justify-between items-center mb-6">
                        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-[#1f5aa2] text-white text-xs font-bold uppercase tracking-wider shadow-sm">
                            <span>🔥</span> Uji Coba Gratis 14 Hari (Akses Penuh)
                        </div>
                    </div>
                    
                    <h3 class="text-3xl md:text-4xl font-black font-display text-slate-900 mb-2">Paket Jempol</h3>
                    <p class="text-slate-600 text-sm mb-6 leading-relaxed">Akses semua fitur kasir premium tanpa batas: kelola multi-kasir, kontrol stok otomatis, laporan laba-rugi lengkap, dan asisten AI pintar.</p>
                    
                    <!-- Main Uji Coba Gratis Rp 0 Display -->
                    <div class="flex flex-col mb-8 bg-[#1f5aa2]/5 p-6 rounded-2xl border border-[#1f5aa2]/20 space-y-3">
                        <div class="flex items-baseline justify-between flex-wrap gap-2 border-b border-[#1f5aa2]/15 pb-4">
                            <div class="flex items-baseline">
                                <span class="text-5xl md:text-6xl font-black font-display text-slate-900 tracking-tight">Rp 0</span>
                                <span class="text-slate-500 ml-2 text-xs font-semibold">/ 14 Hari Pertama</span>
                            </div>
                            <span class="text-[10px] font-bold text-[#1f5aa2] bg-[#1f5aa2]/10 border border-[#1f5aa2]/30 px-2.5 py-1 rounded-md uppercase tracking-wider">
                                Tanpa Kartu Kredit
                            </span>
                        </div>
                        <div class="flex items-center justify-between flex-wrap gap-2 text-xs pt-1">
                            <span class="text-slate-600 font-medium">Setelah trial berakhir, langganan mulai:</span>
                            <span class="px-3 py-1 rounded-full bg-[#1f5aa2] text-white font-extrabold text-xs shadow-sm">
                                Mulai Rp 34rb / Bulan
                            </span>
                        </div>
                    </div>

                    <div class="border-t border-slate-200 pt-6 mb-8">
                        <p class="text-xs font-bold text-[#1f5aa2] uppercase tracking-widest mb-4">Fitur Premium Terhitung:</p>
                        <ul class="space-y-4">
                            <li class="flex items-start gap-3 text-slate-800">
                                <div class="flex-shrink-0 w-5 h-5 rounded-full bg-[#1f5aa2]/10 border border-[#1f5aa2]/30 flex items-center justify-center mt-0.5">
                                    <svg class="w-3 h-3 text-[#1f5aa2]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                                </div>
                                <span class="text-sm font-bold text-slate-900">Maksimal 1.000 Transaksi Penjualan / Hari</span>
                            </li>
                            <li class="flex items-start gap-3 text-slate-800">
                                <div class="flex-shrink-0 w-5 h-5 rounded-full bg-[#1f5aa2]/10 border border-[#1f5aa2]/30 flex items-center justify-center mt-0.5">
                                    <svg class="w-3 h-3 text-[#1f5aa2]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                                </div>
                                <span class="text-sm font-bold text-slate-900">Maksimal 500 Produk & 1.000 Varian</span>
                            </li>
                            <li class="flex items-start gap-3 text-slate-800">
                                <div class="flex-shrink-0 w-5 h-5 rounded-full bg-[#1f5aa2]/10 border border-[#1f5aa2]/30 flex items-center justify-center mt-0.5">
                                    <svg class="w-3 h-3 text-[#1f5aa2]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                                </div>
                                <span class="text-sm font-bold text-slate-900">Owner + Max 5 Akun Staf Kasir (Hak Akses)</span>
                            </li>
                            <li class="flex items-start gap-3 text-slate-800">
                                <div class="flex-shrink-0 w-5 h-5 rounded-full bg-[#1f5aa2]/10 border border-[#1f5aa2]/30 flex items-center justify-center mt-0.5">
                                    <svg class="w-3 h-3 text-[#1f5aa2]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                                </div>
                                <span class="text-sm font-bold text-slate-900">Jari AI & Rekomendasi Stok Pintar</span>
                            </li>
                            <li class="flex items-start gap-3 text-slate-800">
                                <div class="flex-shrink-0 w-5 h-5 rounded-full bg-[#1f5aa2]/10 border border-[#1f5aa2]/30 flex items-center justify-center mt-0.5">
                                    <svg class="w-3 h-3 text-[#1f5aa2]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                                </div>
                                <span class="text-sm font-medium text-slate-600">Cetak Struk Bluetooth & Laporan Laba/Rugi Complete</span>
                            </li>
                        </ul>
                    </div>
                </div>

                <div class="mt-8">
                    <a href="https://app.jaripos.com/register" data-track="pricing-cta-jempol-trial" class="block w-full text-center px-6 py-4.5 rounded-2xl bg-[#1f5aa2] hover:bg-[#164075] active:scale-95 text-white font-black text-lg shadow-lg transition-colors duration-300 ease-out">
                        Coba Gratis 14 Hari Sekarang
                    </a>
                    
                    <p class="mt-4 text-center text-slate-500 text-xs leading-relaxed">
                        Otomatis beralih ke Paket Kelingking (Gratis) setelah 14 hari tanpa biaya mendadak.
                    </p>
                </div>
            </div>

            <!-- RIGHT: Paket Kelingking (Free Forever) -->
            <div data-aos="fade-left" class="w-full lg:col-span-5 bg-slate-50 rounded-3xl md:rounded-[2.5rem] p-8 md:p-10 border border-slate-200 shadow-sm flex flex-col justify-between relative">
                <div class="relative z-10">
                    <div class="inline-flex items-center gap-2 px-3.5 py-1 rounded-full bg-slate-200 text-slate-700 text-xs font-bold mb-6 uppercase tracking-wider">
                        Gratis Selamanya
                    </div>
                    
                    <h3 class="text-3xl font-black font-display text-slate-900 mb-2">Paket Kelingking</h3>
                    <p class="text-slate-600 text-sm mb-6 leading-relaxed">Cocok untuk usaha perintis atau toko mikro yang ingin mendigitalisasikan transaksi harian secara sederhana.</p>
                    
                    <div class="flex items-baseline mb-8">
                        <span class="text-4xl md:text-5xl font-black font-display text-slate-900">Rp 0</span>
                        <span class="text-slate-500 ml-2 text-sm font-medium">/ Selamanya</span>
                    </div>

                    <div class="border-t border-slate-200 pt-6 mb-8">
                        <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-4">Fitur Paket Gratis:</p>
                        <ul class="space-y-4">
                            <li class="flex items-start gap-3 text-slate-700">
                                <div class="flex-shrink-0 w-5 h-5 rounded-full bg-slate-200 flex items-center justify-center mt-0.5">
                                    <svg class="w-3 h-3 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                                </div>
                                <span class="text-sm font-medium">Maksimal <strong>50 transaksi</strong> / hari</span>
                            </li>
                            <li class="flex items-start gap-3 text-slate-700">
                                <div class="flex-shrink-0 w-5 h-5 rounded-full bg-slate-200 flex items-center justify-center mt-0.5">
                                    <svg class="w-3 h-3 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                                </div>
                                <span class="text-sm font-medium">Maksimal <strong>10 produk</strong> (25 Varian)</span>
                            </li>
                            <li class="flex items-start gap-3 text-slate-700">
                                <div class="flex-shrink-0 w-5 h-5 rounded-full bg-slate-200 flex items-center justify-center mt-0.5">
                                    <svg class="w-3 h-3 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                                </div>
                                <span class="text-sm font-medium">1 Akun <strong>Owner Utama</strong></span>
                            </li>
                            <li class="flex items-start gap-3 text-slate-700">
                                <div class="flex-shrink-0 w-5 h-5 rounded-full bg-slate-200 flex items-center justify-center mt-0.5">
                                    <svg class="w-3 h-3 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                                </div>
                                <span class="text-sm font-medium">Laporan penjualan harian dasar</span>
                            </li>
                            <li class="flex items-start gap-3 text-slate-400 line-through">
                                <div class="flex-shrink-0 w-5 h-5 rounded-full bg-slate-100 flex items-center justify-center mt-0.5">
                                    <svg class="w-3 h-3 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"></path></svg>
                                </div>
                                <span class="text-sm">Tanpa Jari AI & Rekomendasi Stok</span>
                            </li>
                        </ul>
                    </div>
                </div>

                <div class="mt-8">
                    <a href="https://app.jaripos.com/register" data-track="pricing-cta-free" class="block w-full text-center px-6 py-4 rounded-2xl bg-white border border-slate-300 text-slate-700 font-bold hover:bg-slate-100 transition duration-300 text-sm">
                        Mulai Paket Gratis
                    </a>
                </div>
            </div>

        </div>

        <!-- Bottom Banner Card: Detail Paket & Perbandingan (Matching Features.astro Style) -->
        <div data-aos="fade-up" data-aos-delay="200" class="max-w-6xl mx-auto mt-12 p-8 bg-[#1f5aa2] rounded-3xl text-white shadow-xl flex flex-col md:flex-row items-center justify-between gap-6">
            <div class="max-w-2xl text-left">
                <span class="text-xs font-bold uppercase tracking-wider text-sky-200 bg-white/10 px-3 py-1 rounded-md mb-3 inline-block">Perbandingan Paket Lengkap</span>
                <h3 class="text-2xl md:text-3xl font-bold font-display text-white mb-2">Ingin Bandingkan Semua Benefit Paket Kasir?</h3>
                <p class="text-sky-100 text-sm md:text-base leading-relaxed">Bandingkan rincian limit transaksi harian, hak akses akun staf kasir, cetak struk Bluetooth, hingga laporan laba-rugi lengkap secara detail.</p>
            </div>
            <a 
                href="/harga" 
                class="group inline-flex items-center gap-2 px-6 py-3.5 bg-white text-[#1f5aa2] hover:bg-slate-100 active:scale-95 rounded-full font-bold shadow-md transition-all duration-300 flex-shrink-0"
            >
                <span>Lihat Detail Paket</span> <i class="fas fa-arrow-right text-xs transition-transform duration-300 group-hover:translate-x-1"></i>
            </a>
        </div>
    </div>
</section>

