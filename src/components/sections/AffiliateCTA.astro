---
---
<section class="py-10 bg-white relative overflow-hidden border-t border-slate-100">
    <!-- Grid Pattern Overlay -->
    <div class="absolute inset-0 bg-[radial-gradient(#e5e7eb_1px,transparent_1px)] [background-size:20px_20px] opacity-40 pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <!-- Horizontal Banner Card: Gold Accent on Dark Slate (Matching Footer) -->
        <div data-aos="zoom-in" class="bg-gradient-to-r from-slate-950 via-slate-900 to-indigo-950 rounded-2xl p-6 md:p-8 text-white relative overflow-hidden shadow-lg border border-[#dfba6b]/30 shadow-[0_10px_40px_rgba(223,186,107,0.05)] flex flex-col md:flex-row items-center justify-between gap-6">
            <!-- Decorative subtle gold glow inside -->
            <div class="absolute -right-10 -top-10 w-40 h-40 bg-[#dfba6b]/5 rounded-full blur-[40px] pointer-events-none"></div>
            <div class="absolute -left-10 -bottom-10 w-40 h-40 bg-indigo-500/5 rounded-full blur-[40px] pointer-events-none"></div>
            
            <div class="flex flex-row items-center gap-4 relative z-10 w-full">
                <!-- Icon: only visible on desktop (md and up) -->
                <div class="hidden md:flex w-12 h-12 rounded-2xl bg-[#dfba6b]/10 border border-[#dfba6b]/20 items-center justify-center text-[#dfba6b] text-xl shrink-0">
                    🤝
                </div>
                <div class="space-y-1">
                    <h3 class="text-lg md:text-xl font-black text-white">Gabung Program Kemitraan Afiliasi JARIPOS</h3>
                    <p class="text-slate-400 text-xs md:text-sm max-w-xl font-medium">
                        Dapatkan komisi 20% untuk setiap pembelian atau perpanjangan paket menggunakan voucher/kode referal Anda dengan merekomendasikan JARIPOS ke rekan bisnis Anda.
                    </p>
                </div>
            </div>
            
            <a 
                href="/affiliate" 
                data-track="affiliate-cta-learn"
                class="w-full md:w-auto text-center px-6 py-3.5 rounded-xl bg-gradient-to-r from-[#dfba6b] to-[#c29c47] hover:brightness-110 text-slate-950 font-bold text-sm transition-all duration-300 shadow-md hover:scale-[1.02] shrink-0 relative z-10 cursor-pointer"
            >
                Pelajari Selengkapnya <i class="fas fa-arrow-right ml-1"></i>
            </a>
        </div>
    </div>
</section>
