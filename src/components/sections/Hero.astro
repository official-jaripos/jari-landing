---
---
<section class="pt-32 pb-20 lg:pt-56 lg:pb-32 overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative">

        <div class="flex flex-col items-center relative z-10">
            
            <!-- Hero Content -->
            <div class="max-w-4xl mx-auto flex flex-col items-center text-center mb-12 md:mb-20">

                <!-- Headline -->
                <h1 data-aos="fade-up" data-aos-delay="200" class="text-4xl md:text-7xl font-black font-display text-[#121417] leading-tight tracking-tight mb-6">
                    Aplikasi Kasir Pintar <br class="hidden md:block" />
                    <span>Paling Terjangkau untuk UMKM</span>
                </h1>

                <!-- Subheadline -->
                <p data-aos="fade-up" data-aos-delay="300" class="text-lg md:text-xl text-slate-600 mb-10 max-w-2xl leading-relaxed">
                    Tinggalkan cara manual yang ribet. Jaripos memudahkan migrasi bisnis Anda ke digital—atur transaksi dan stok dalam satu genggaman, kapan saja dan di mana saja.
                </p>

                <!-- CTA Buttons -->
                <div data-aos="fade-up" data-aos-delay="400" class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto justify-center">
                    <a href="https://app.jaripos.com/register" data-track="hero-cta-primary" class="group inline-flex items-center justify-center rounded-full px-8 py-4 font-bold text-white bg-[#1f5aa2] hover:bg-[#164075] active:scale-95 transition-colors duration-300 ease-out shadow-lg shadow-[#1f5aa2]/20">
                        <span class="mr-2">Coba Gratis Sekarang</span>
                        <svg class="h-5 w-5 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
                    </a>
                    <a href="https://wa.me/6285875502569?text=Halo%2C%20saya%20tertarik%20dengan%20Jaripos" target="_blank" data-track="hero-cta-whatsapp" class="px-8 py-4 rounded-full text-slate-700 bg-white border-2 border-slate-200 hover:bg-slate-50 hover:border-slate-300 active:scale-95 transition-colors duration-300 ease-out font-semibold flex items-center justify-center gap-2 group">
                        <div class="w-8 h-8 rounded-full bg-green-100 flex items-center justify-center text-green-600">
                            <i class="fab fa-whatsapp text-lg"></i>
                        </div>
                        Hubungi Kami
                    </a>
                </div>

                <!-- Trust Bar -->
                <div data-aos="fade-up" data-aos-delay="500" class="flex items-center justify-center gap-2 mt-8 text-slate-500 text-sm font-medium">
                    <svg class="w-4 h-4 text-[#1f5aa2]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                    <span>Aplikasi kasir terintegrasi untuk berbagai bidang toko & usaha</span>
                </div>
            </div>

            <!-- Bottom: Interactive Image Accordion (Desktop) / Carousel (Mobile) -->
            <div data-aos="fade-up" data-aos-delay="500" class="relative w-full max-w-6xl mx-auto h-[350px] sm:h-[450px] md:h-[600px] flex justify-center items-center">
                
                <!-- Desktop View: Flex Accordion Stack -->
                <div class="hidden md:flex justify-center items-stretch w-full h-full gap-6 group/stack">
                    {[
                        { src: '/assets/images/pos-preview.png', title: 'Dashboard Kasir' },
                        { src: '/assets/images/retail-context.png', title: 'Kelola Stok Mudah' },
                        { src: '/assets/images/pos-preview.png', title: 'Laporan Otomatis' },
                    ].map((item, index) => {
                        const isDefault = index === 0;
                        return (
                            <div 
                                class={`hero-card card-3d-tilt relative transition-all duration-500 ease-[cubic-bezier(0.2,0,0,1)] overflow-hidden rounded-3xl group/card cursor-pointer shadow-xl border border-slate-100
                                    ${isDefault ? 'flex-[10]' : 'flex-[1]'}
                                    hover:!flex-[12] group-hover/stack:hover:!flex-[12] group-hover/stack:flex-[1]
                                `}
                                style="will-change: flex, transform; transform: translateZ(0);"
                            >
                                <img 
                                    src={item.src} 
                                    alt={item.title} 
                                    class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-out group-hover/card:scale-110" 
                                    style="will-change: transform;"
                                />
                                
                                <div class={`absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent transition-opacity duration-500 ${isDefault ? 'opacity-100 group-hover/stack:opacity-0 group-hover/card:!opacity-100' : 'opacity-0 group-hover/card:opacity-100'}`}>
                                    <div class={`absolute bottom-6 left-6 right-6 text-left transition-all duration-500 ${isDefault ? 'translate-y-0 group-hover/stack:translate-y-4 group-hover/card:!translate-y-0' : 'translate-y-4 group-hover/card:translate-y-0'}`}>
                                        <p class="text-white font-bold text-lg md:text-xl">{item.title}</p>
                                    </div>
                                </div>
                            </div>
                        );
                    })}
                </div>

                <!-- Mobile View: Auto-fading Single Image Carousel -->
                <div class="flex md:hidden relative w-full h-full overflow-hidden rounded-2xl shadow-xl border border-slate-100">
                    {[
                        { src: '/assets/images/pos-preview.png', title: 'Dashboard Kasir' },
                        { src: '/assets/images/retail-context.png', title: 'Kelola Stok Mudah' },
                        { src: '/assets/images/pos-preview.png', title: 'Laporan Otomatis' },
                    ].map((item, index) => {
                        return (
                            <div 
                                class={`mobile-carousel-slide absolute inset-0 w-full h-full transition-all duration-1000 ease-in-out ${index === 0 ? 'opacity-100 z-10' : 'opacity-0 z-0'}`}
                                data-index={index}
                            >
                                <img 
                                    src={item.src} 
                                    alt={item.title} 
                                    class="w-full h-full object-cover" 
                                />
                                <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/30 to-transparent">
                                    <div class="absolute bottom-6 left-6 right-6 text-left">
                                        <p class="text-white font-bold text-base sm:text-lg">{item.title}</p>
                                    </div>
                                </div>
                            </div>
                        );
                    })}
                    
                    <!-- Indicator Dots -->
                    <div class="absolute bottom-4 right-6 flex space-x-2 z-20">
                        <span class="carousel-dot w-2 h-2 rounded-full bg-white opacity-100 transition-opacity duration-300" data-slide="0"></span>
                        <span class="carousel-dot w-2 h-2 rounded-full bg-white opacity-40 transition-opacity duration-300" data-slide="1"></span>
                        <span class="carousel-dot w-2 h-2 rounded-full bg-white opacity-40 transition-opacity duration-300" data-slide="2"></span>
                    </div>
                </div>

            </div>
        </div>
    </div>
</section>

<script is:inline>
    function initMobileCarousel() {
        const slides = document.querySelectorAll('.mobile-carousel-slide');
        const dots = document.querySelectorAll('.carousel-dot');
        if (slides.length === 0) return;

        let currentSlide = 0;
        const totalSlides = slides.length;

        function showSlide(index) {
            slides.forEach((slide, i) => {
                if (i === index) {
                    slide.classList.remove('opacity-0', 'z-0');
                    slide.classList.add('opacity-100', 'z-10');
                } else {
                    slide.classList.remove('opacity-100', 'z-10');
                    slide.classList.add('opacity-0', 'z-0');
                }
            });

            dots.forEach((dot, i) => {
                if (i === index) {
                    dot.classList.remove('opacity-40');
                    dot.classList.add('opacity-100');
                } else {
                    dot.classList.remove('opacity-100');
                    dot.classList.add('opacity-40');
                }
            });
        }

        setInterval(() => {
            currentSlide = (currentSlide + 1) % totalSlides;
            showSlide(currentSlide);
        }, 4000);
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initMobileCarousel);
    } else {
        initMobileCarousel();
    }
</script>
