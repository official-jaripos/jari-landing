---
---
<section class="pt-32 pb-20 lg:pt-56 lg:pb-32 overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative">

        <div class="flex flex-col items-center relative z-10">
            
            <!-- Hero Content -->
            <div class="max-w-4xl mx-auto flex flex-col items-center text-center mb-12 md:mb-20">

                <!-- Headline -->
                <h1 data-aos="fade-up" data-aos-delay="200" class="text-4xl md:text-7xl font-extrabold text-slate-900 leading-tight tracking-tight mb-6">
                    Aplikasi Kasir Pintar <br class="hidden md:block" />
                    <span class="text-slate-900">Paling Terjangkau untuk UMKM</span>
                </h1>

                <!-- Subheadline -->
                <p data-aos="fade-up" data-aos-delay="300" class="text-lg md:text-xl text-slate-600 mb-10 max-w-2xl leading-relaxed">
                    Tinggalkan cara manual yang ribet. Jaripos memudahkan migrasi bisnis Anda ke digital—atur transaksi dan stok dalam satu genggaman, kapan saja dan di mana saja.
                </p>

                <!-- CTA Buttons -->
                <div data-aos="fade-up" data-aos-delay="400" class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto justify-center">
                    <a href="https://app.jaripos.com/register" data-track="hero-cta-primary" class="group relative inline-flex items-center justify-center overflow-hidden rounded-full px-8 py-4 font-bold text-white bg-cyan-brand duration-300 hover:brightness-110 shadow-xl shadow-cyan-900/20">
                        <div class="absolute inset-0 flex h-full w-full justify-center [transform:skew(-12deg)_translateX(-100%)] group-hover:duration-1000 group-hover:[transform:skew(-12deg)_translateX(100%)]">
                            <div class="relative h-full w-8 bg-white/20"></div>
                        </div>
                        <span class="mr-2 relative">Coba Gratis Sekarang</span>
                        <svg class="h-5 w-5 relative transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
                    </a>
                    <a href="https://wa.me/6285875502569?text=Halo%2C%20saya%20tertarik%20dengan%20Jaripos" target="_blank" data-track="hero-cta-whatsapp" class="px-8 py-4 rounded-full text-slate-700 bg-white border-2 border-slate-200 hover:bg-slate-50 hover:border-slate-300 transition font-semibold flex items-center justify-center gap-2 group">
                        <div class="w-8 h-8 rounded-full bg-green-100 flex items-center justify-center text-green-600 group-hover:scale-110 transition">
                            <i class="fab fa-whatsapp text-lg"></i>
                        </div>
                        Hubungi Kami
                    </a>
                </div>

                <!-- Trust Bar -->
                <div data-aos="fade-up" data-aos-delay="500" class="flex items-center justify-center gap-2 mt-8 text-slate-400 text-sm">
                    <svg class="w-4 h-4 text-brand-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                    <span>Satu aplikasi untuk semua kebutuhan toko Anda</span>
                </div>
            </div>

            <!-- Bottom: Interactive Image Accordion -->
            <div data-aos="fade-up" data-aos-delay="500" class="relative w-full max-w-6xl mx-auto h-[400px] md:h-[600px] flex justify-center items-center">
                <!-- Flex Accordion Stack -->
                <div class="relative flex justify-center items-stretch w-full h-full gap-2 md:gap-6 group/stack">
                    {[
                        { src: '/assets/images/pos-preview.png', title: 'Dashboard Kasir' },
                        { src: '/assets/images/retail-context.png', title: 'Kelola Stok Mudah' },
                        { src: '/assets/images/pos-preview.png', title: 'Laporan Otomatis' },
                    ].map((item, index) => {
                        const isDefault = index === 0;
                        return (
                            <div 
                                class={`hero-card card-3d-tilt relative transition-all duration-500 ease-[cubic-bezier(0.2,0,0,1)] overflow-hidden rounded-3xl group/card cursor-pointer shadow-xl border border-slate-100
                                    ${isDefault ? 'flex-[4] md:flex-[10] group-hover/stack:flex-[1]' : 'flex-[1]'}
                                    hover:!flex-[12]
                                `}
                                style="will-change: flex, transform; transform: translateZ(0);"
                            >
                                <img 
                                    src={item.src} 
                                    alt={item.title} 
                                    class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-out group-hover/card:scale-110" 
                                    style="will-change: transform;"
                                />
                                
                                <div class={`absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent transition-opacity duration-500 ${isDefault ? 'opacity-100 group-hover/stack:opacity-0 group-hover/card:!opacity-100' : 'opacity-0 group-hover/card:opacity-100'}`}>
                                    <div class={`absolute bottom-6 left-6 right-6 text-left transition-all duration-500 ${isDefault ? 'translate-y-0 group-hover/stack:translate-y-4 group-hover/card:!translate-y-0' : 'translate-y-4 group-hover/card:translate-y-0'}`}>
                                        <p class="text-white font-bold text-lg md:text-xl">{item.title}</p>
                                    </div>
                                </div>
                            </div>
                        );
                    })}
                </div>
            </div>
        </div>
    </div>
</section>
