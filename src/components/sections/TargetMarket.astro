---
---
<section id="target-market" class="py-24 bg-white overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16" data-aos="fade-up">
            <h2 class="text-3xl md:text-4xl font-bold text-slate-900">Solusi Tepat untuk Usaha Anda</h2>
            <p class="text-slate-500 mt-4 max-w-2xl mx-auto">Dirancang khusus untuk memenuhi kebutuhan operasional berbagai jenis bisnis agar lebih profesional dan terorganisir.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <!-- Market 1: Sembako -->
            <div data-aos="fade-up" data-aos-delay="100" class="group relative p-7 rounded-3xl bg-slate-50 border border-slate-100 hover:bg-[#1f5aa2] hover:border-[#164075] transition-all duration-500">
                <div class="relative z-10">
                    <div class="w-14 h-14 bg-white rounded-2xl flex items-center justify-center text-[#1f5aa2] mb-5 shadow-sm group-hover:bg-[#164075] group-hover:text-white transition-all duration-300">
                        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 mb-3 group-hover:text-white transition-colors">Toko Sembako & Grosir</h3>
                    <p class="text-slate-500 group-hover:text-sky-100 transition-colors leading-relaxed text-sm">Kelola ribuan item stok dengan mudah. Pantau harga modal dan jual secara otomatis.</p>
                    <ul class="mt-5 space-y-2">
                        <li class="flex items-center gap-2 text-sm text-slate-600 group-hover:text-white transition-colors">
                            <svg class="w-4 h-4 text-[#1f5aa2] group-hover:text-sky-300 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                            <span>Scan Barcode</span>
                        </li>
                        <li class="flex items-center gap-2 text-sm text-slate-600 group-hover:text-white transition-colors">
                            <svg class="w-4 h-4 text-[#1f5aa2] group-hover:text-sky-300 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                            <span>Harga Grosir & Eceran</span>
                        </li>
                    </ul>
                </div>
                <div class="absolute bottom-4 right-4 opacity-5 group-hover:opacity-10 transition-opacity">
                     <svg class="w-28 h-28" fill="currentColor" viewBox="0 0 24 24"><path d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
                </div>
            </div>

            <!-- Market 2: F&B -->
            <div data-aos="fade-up" data-aos-delay="200" class="group relative p-7 rounded-3xl bg-slate-50 border border-slate-100 hover:bg-[#1f5aa2] hover:border-[#164075] transition-all duration-500">
                <div class="relative z-10">
                    <div class="w-14 h-14 bg-white rounded-2xl flex items-center justify-center text-[#1f5aa2] mb-5 shadow-sm group-hover:bg-[#164075] group-hover:text-white transition-all duration-300">
                        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"></path></svg>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 mb-3 group-hover:text-white transition-colors">Kafe, Resto & Kedai</h3>
                    <p class="text-slate-500 group-hover:text-sky-100 transition-colors leading-relaxed text-sm">Proses pesanan kasir cepat dengan opsi varian rasa & ukuran. Cetak struk pesanan dapur secara fleksibel.</p>
                    <ul class="mt-5 space-y-2">
                        <li class="flex items-center gap-2 text-sm text-slate-600 group-hover:text-white transition-colors">
                            <svg class="w-4 h-4 text-[#1f5aa2] group-hover:text-sky-300 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                            <span>Pesanan Kasir Cepat</span>
                        </li>
                        <li class="flex items-center gap-2 text-sm text-slate-600 group-hover:text-white transition-colors">
                            <svg class="w-4 h-4 text-[#1f5aa2] group-hover:text-sky-300 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                            <span>Multi-Varian Produk</span>
                        </li>
                    </ul>
                </div>
                <div class="absolute bottom-4 right-4 opacity-5 group-hover:opacity-10 transition-opacity">
                    <svg class="w-28 h-28" fill="currentColor" viewBox="0 0 24 24"><path d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"></path></svg>
                </div>
            </div>

            <!-- Market 3: Toko Kelontong -->
            <div data-aos="fade-up" data-aos-delay="300" class="group relative p-7 rounded-3xl bg-slate-50 border border-slate-100 hover:bg-[#1f5aa2] hover:border-[#164075] transition-all duration-500">
                <div class="relative z-10">
                    <div class="w-14 h-14 bg-white rounded-2xl flex items-center justify-center text-[#1f5aa2] mb-5 shadow-sm group-hover:bg-[#164075] group-hover:text-white transition-all duration-300">
                        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 mb-3 group-hover:text-white transition-colors">Toko Kelontong</h3>
                    <p class="text-slate-500 group-hover:text-sky-100 transition-colors leading-relaxed text-sm">Kelola ratusan item harga kecil dengan margin tipis. Catat penjualan harian tanpa ribet.</p>
                    <ul class="mt-5 space-y-2">
                        <li class="flex items-center gap-2 text-sm text-slate-600 group-hover:text-white transition-colors">
                            <svg class="w-4 h-4 text-[#1f5aa2] group-hover:text-sky-300 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                            <span>Stok Opname Cepat</span>
                        </li>
                        <li class="flex items-center gap-2 text-sm text-slate-600 group-hover:text-white transition-colors">
                            <svg class="w-4 h-4 text-[#1f5aa2] group-hover:text-sky-300 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                            <span>Profit per Item</span>
                        </li>
                    </ul>
                </div>
                <div class="absolute bottom-4 right-4 opacity-5 group-hover:opacity-10 transition-opacity">
                    <svg class="w-28 h-28" fill="currentColor" viewBox="0 0 24 24"><path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
                </div>
            </div>

            <!-- Market 4: Fashion & Aksesoris -->
            <div data-aos="fade-up" data-aos-delay="100" class="group relative p-7 rounded-3xl bg-slate-50 border border-slate-100 hover:bg-[#1f5aa2] hover:border-[#164075] transition-all duration-500">
                <div class="relative z-10">
                    <div class="w-14 h-14 bg-white rounded-2xl flex items-center justify-center text-[#1f5aa2] mb-5 shadow-sm group-hover:bg-[#164075] group-hover:text-white transition-all duration-300">
                        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path></svg>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 mb-3 group-hover:text-white transition-colors">Fashion & Aksesoris</h3>
                    <p class="text-slate-500 group-hover:text-sky-100 transition-colors leading-relaxed text-sm">Atur varian ukuran dan warna dengan rapi. Kategorisasi koleksi agar mudah ditemukan.</p>
                    <ul class="mt-5 space-y-2">
                        <li class="flex items-center gap-2 text-sm text-slate-600 group-hover:text-white transition-colors">
                            <svg class="w-4 h-4 text-[#1f5aa2] group-hover:text-sky-300 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                            <span>Multi-Varian (Ukuran & Warna)</span>
                        </li>
                        <li class="flex items-center gap-2 text-sm text-slate-600 group-hover:text-white transition-colors">
                            <svg class="w-4 h-4 text-[#1f5aa2] group-hover:text-sky-300 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                            <span>Kategori Koleksi</span>
                        </li>
                    </ul>
                </div>
                <div class="absolute bottom-4 right-4 opacity-5 group-hover:opacity-10 transition-opacity">
                    <svg class="w-28 h-28" fill="currentColor" viewBox="0 0 24 24"><path d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path></svg>
                </div>
            </div>

            <!-- Market 5: Bengkel & Sparepart -->
            <div data-aos="fade-up" data-aos-delay="200" class="group relative p-7 rounded-3xl bg-slate-50 border border-slate-100 hover:bg-[#1f5aa2] hover:border-[#164075] transition-all duration-500">
                <div class="relative z-10">
                    <div class="w-14 h-14 bg-white rounded-2xl flex items-center justify-center text-[#1f5aa2] mb-5 shadow-sm group-hover:bg-[#164075] group-hover:text-white transition-all duration-300">
                        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 mb-3 group-hover:text-white transition-colors">Bengkel & Sparepart</h3>
                    <p class="text-slate-500 group-hover:text-sky-100 transition-colors leading-relaxed text-sm">Cari stok cepat by kode part. Catat nota servis dan kelola inventori sparepart dengan rapi.</p>
                    <ul class="mt-5 space-y-2">
                        <li class="flex items-center gap-2 text-sm text-slate-600 group-hover:text-white transition-colors">
                            <svg class="w-4 h-4 text-[#1f5aa2] group-hover:text-sky-300 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                            <span>Pencarian Kode Part</span>
                        </li>
                        <li class="flex items-center gap-2 text-sm text-slate-600 group-hover:text-white transition-colors">
                            <svg class="w-4 h-4 text-[#1f5aa2] group-hover:text-sky-300 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                            <span>Cetak Nota Servis</span>
                        </li>
                    </ul>
                </div>
                <div class="absolute bottom-4 right-4 opacity-5 group-hover:opacity-10 transition-opacity">
                    <svg class="w-28 h-28" fill="currentColor" viewBox="0 0 24 24"><path d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                </div>
            </div>

            <!-- Market 6: Apotek & Toko Obat -->
            <div data-aos="fade-up" data-aos-delay="300" class="group relative p-7 rounded-3xl bg-slate-50 border border-slate-100 hover:bg-[#1f5aa2] hover:border-[#164075] transition-all duration-500">
                <div class="relative z-10">
                    <div class="w-14 h-14 bg-white rounded-2xl flex items-center justify-center text-[#1f5aa2] mb-5 shadow-sm group-hover:bg-[#164075] group-hover:text-white transition-all duration-300">
                        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 mb-3 group-hover:text-white transition-colors">Apotek & Toko Obat</h3>
                    <p class="text-slate-500 group-hover:text-sky-100 transition-colors leading-relaxed text-sm">Kelola stok obat by batch dengan kategori rapi. Pantau tanggal kadaluarsa otomatis.</p>
                    <ul class="mt-5 space-y-2">
                        <li class="flex items-center gap-2 text-sm text-slate-600 group-hover:text-white transition-colors">
                            <svg class="w-4 h-4 text-[#1f5aa2] group-hover:text-sky-300 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                            <span>Manajemen Batch & Kadaluarsa</span>
                        </li>
                        <li class="flex items-center gap-2 text-sm text-slate-600 group-hover:text-white transition-colors">
                            <svg class="w-4 h-4 text-[#1f5aa2] group-hover:text-sky-300 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                            <span>Kategori Obat & Suplemen</span>
                        </li>
                    </ul>
                </div>
                <div class="absolute bottom-4 right-4 opacity-5 group-hover:opacity-10 transition-opacity">
                    <svg class="w-28 h-28" fill="currentColor" viewBox="0 0 24 24"><path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg>
                </div>
            </div>
        </div>

        <!-- Call to Action -->
        <div data-aos="fade-up" class="mt-16 p-8 md:p-12 rounded-3xl bg-[#1f5aa2] text-center relative overflow-hidden shadow-xl">
            <div class="relative z-10 max-w-2xl mx-auto">
                <h4 class="text-2xl md:text-3xl font-bold font-display text-white mb-3">Bisnis Anda berbeda dari kategori di atas?</h4>
                <p class="text-sky-100 mb-8 text-base md:text-lg leading-relaxed">Tenang, sistem Jaripos sangat fleksibel untuk berbagai jenis usaha dagang lainnya. Konsultasikan kebutuhan Anda dengan tim kami.</p>
                <a href="https://wa.me/6285875502569" target="_blank" class="group inline-flex items-center gap-2.5 px-8 py-4 bg-white text-[#1f5aa2] font-bold rounded-full hover:bg-slate-100 active:scale-95 transition-all duration-300 shadow-md">
                    <i class="fab fa-whatsapp text-xl text-green-600"></i>
                    <span>Konsultasi Gratis Sekarang</span>
                </a>
            </div>
        </div>
    </div>
</section>
